/target
# FT-107 — the TC-889 external-consumer fixture builds in its own sibling target/.
product-cli/tests/fixtures/external-core-consumer/target/
Cargo.lock
.product.lock
*.product-tmp.*
.proptest-regressions
*:Zone.Identifier

# Product CLI — generated files
.product/graph/
.product/sessions/
.product/checklist.md
tests/__pycache__/

# session.json is the regenerable working cache; the committed <product>.ttl is
# the authoritative spec, and the session reloads from it (pf::session::load).
.product/products/*/session.json
# legacy pre-products/ location of the same cache
.product/author-domain/*/session.json

# build run I/O — frozen context, session metrics, logs (regenerable per `product build`)
.product/build/

# Playwright MCP scratch (headless browser profile/output)
.playwright-mcp/
