{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/graph/**",
              "ui_kits/aio-renderer/**",
              "ui_kits/what-graph/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:IBM Plex Sans|IBM Plex Mono|IBM Plex Serif))/i]",
        "message": "Font not provided by the design system. Available: IBM Plex Sans, IBM Plex Mono, IBM Plex Serif."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|iconRight|kicker|fullWidth|as|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, iconRight, kicker, fullWidth, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|eyebrow|title|accent|padding|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: variant, eyebrow, title, accent, padding, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:elevation|draft|flat)$/]",
        "message": "<Card> variant must be one of 'elevation' | 'draft' | 'flat'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ConformanceBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:level|showLadder|key|ref|className|style|children)$/]",
        "message": "<ConformanceBadge> doesn't accept that prop. Declared props: level, showLadder."
      },
      {
        "selector": "JSXOpeningElement[name.name='ConformanceBadge'] > JSXAttribute[name.name='level'] > Literal[value!=/^(?:described|realised|verified|delivered)$/]",
        "message": "<ConformanceBadge> level must be one of 'described' | 'realised' | 'verified' | 'delivered'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EMNode'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|label|note|selected|showKind|onClick|key|ref|className|style|children)$/]",
        "message": "<EMNode> doesn't accept that prop. Declared props: kind, label, note, selected, showKind, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='EMNode'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:command|view|read-model|event|trigger|ui-step)$/]",
        "message": "<EMNode> kind must be one of 'command' | 'view' | 'read-model' | 'event' | 'trigger' | 'ui-step'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PhaseStepper'] > JSXAttribute > JSXIdentifier[name!=/^(?:current|until|key|ref|className|style|children)$/]",
        "message": "<PhaseStepper> doesn't accept that prop. Declared props: current, until."
      },
      {
        "selector": "JSXOpeningElement[name.name='PhaseStepper'] > JSXAttribute[name.name='current'] > Literal[value!=/^(?:what|how|build)$/]",
        "message": "<PhaseStepper> current must be one of 'what' | 'how' | 'build'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PhaseStepper'] > JSXAttribute[name.name='until'] > Literal[value!=/^(?:what|how|build)$/]",
        "message": "<PhaseStepper> until must be one of 'what' | 'how' | 'build'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatePill'] > JSXAttribute > JSXIdentifier[name!=/^(?:state|label|key|ref|className|style|children)$/]",
        "message": "<StatePill> doesn't accept that prop. Declared props: state, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatePill'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:present|empty|loading|failed|draft|finalized|verified|divergent)$/]",
        "message": "<StatePill> state must be one of 'present' | 'empty' | 'loading' | 'failed' | 'draft' | 'finalized' | 'verified' | 'divergent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|solid|size|children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: tone, solid, size, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|accent|command|view|event|trigger|bridge)$/]",
        "message": "<Tag> tone must be one of 'neutral' | 'accent' | 'command' | 'view' | 'event' | 'trigger' | 'bridge'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Tag> size must be one of 'sm' | 'md'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
